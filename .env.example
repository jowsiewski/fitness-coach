# Intervals.icu
INTERVALS_API_KEY=your_intervals_api_key_here
INTERVALS_ATHLETE_ID=0

# ── AI Provider ─────────────────────────────────────────────
# Obsługiwane: OpenAI, LM Studio, Ollama, lub dowolny serwer
# kompatybilny z OpenAI API (np. vLLM, text-generation-webui).
#
# ── Opcja 1: OpenAI (płatne) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=              ← zostaw puste (domyślne api.openai.com)
#
# ── Opcja 2: LM Studio (darmowe, lokalne) ──
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=qwen2.5-7b-instruct
# OPENAI_BASE_URL=http://192.168.1.100:1234/v1
#
# ── Opcja 3: Ollama (darmowe, lokalne) ──
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.1:8b
# OPENAI_BASE_URL=http://192.168.1.100:11434/v1
#
# ── Opcja 4: Google Gemini (OpenAI-compatible) ──
# OPENAI_API_KEY=your_gemini_api_key
# OPENAI_MODEL=gemini-2.0-flash
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# App
DATABASE_URL=sqlite+aiosqlite:///./data/fitness_coach.db
LOG_LEVEL=INFO
SYNC_INTERVAL_MINUTES=60
